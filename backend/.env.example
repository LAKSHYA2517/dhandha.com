MONGO_URI=mongodb://localhost:27017/compliance_b2b
JWT_SECRET=compliance_b2b_secret_2024
JWT_EXPIRE_DAYS=7
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Google GenAI (Gemini/Gemma via AI Studio) — https://aistudio.google.com/apikey
# Confirm what's actually available to your key via client.models.list().
# Gemma models (as of testing) return 500 errors on image input despite being
# listed as available — text-only works fine. Use a "gemini-*" model for
# GEMINI_VISION_MODEL; gemini-flash-lite-latest is confirmed working here.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-flash-lite-latest
GEMINI_TEXT_MODEL=gemma-4-31b-it

# Qdrant — leave both unset to use an in-memory instance (hackathon/local default)
QDRANT_URL=
QDRANT_API_KEY=

# Meta WhatsApp Cloud API — https://developers.facebook.com/apps > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
# Optional — enables X-Hub-Signature-256 verification on the POST webhook.
# Required for any deployment reachable from the public internet.
WHATSAPP_APP_SECRET=
